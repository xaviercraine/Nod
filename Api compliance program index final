      padding-bottom: 20px;
      margin-bottom: 30px;
    }
    .header h1 {
      font-size: 24px;
      margin-bottom: 5px;
    }
    .header .subtitle {
      font-size: 14px;
      color: #555;
    }
    .header .legal-ref {
      font-size: 12px;
      color: #777;
      margin-top: 8px;
    }
    .meta {
      background: #f8f8f8;
      border: 1px solid #ddd;
      padding: 15px 20px;
      margin-bottom: 30px;
      font-size: 14px;
    }
    .meta strong { display: inline-block; width: 180px; }
