// ---- GET /compliance-program ----

async function handleGetProgram(
  request: Request,
  auth: AuthResult,
): Promise<Response> {
  const supabase = getSupabaseClient();
  const ipAddress = getClientIp(request);

  // 1. Fetch all compliance program data in one RPC call
  const { data, error } = await supabase.rpc("get_compliance_program_data", {
    p_tenant_id: auth.tenantId,
  });

  if (error) {
    if (error.message?.includes("Tenant not found")) {
      return errorResponse("Tenant not found", "TENANT_NOT_FOUND", 404);
    }
    console.error("get_compliance_program_data RPC error:", error.message);
    await alertFounder(
      "Compliance Program: Data Fetch Failed",
      `<p>Tenant: ${auth.tenantId}</p><p>Error: ${error.message}</p>`,
    );
    return errorResponse(
      "Failed to retrieve compliance data",
      "QUERY_FAILED",
      500,
    );
  }

  const rows = Array.isArray(data) ? data : [];
  if (rows.length === 0) {
    return errorResponse("No compliance data found", "NO_DATA", 404);
  }

  const programData: ProgramData = rows[0] as ProgramData;

  // 2. Generate the compliance program
  const program = generateComplianceProgram(programData);

  // 3. Generate HTML document
  const html = generateProgramHtml(program);
  const htmlBytes = new TextEncoder().encode(html);

  // 4. Upload to compliance-reports storage bucket
  const timestamp = new Date().toISOString().replace(/[:.]/g, "-");
  const storagePath = `${auth.tenantId}/compliance-program/program_${timestamp}.html`;

  const { error: uploadError } = await supabase.storage
    .from("compliance-reports")
    .upload(storagePath, htmlBytes, {
      contentType: "text/html; charset=utf-8",
      upsert: false,
    });

  let fileUrl: string | null = null;

  if (uploadError) {
    console.error("Storage upload error:", uploadError.message);
  } else {
    const { data: signedUrlData, error: signedUrlError } = await supabase
      .storage
      .from("compliance-reports")
      .createSignedUrl(storagePath, 7 * 24 * 60 * 60);

    if (signedUrlError) {
      console.error("Signed URL error:", signedUrlError.message);
    } else {
      fileUrl = signedUrlData.signedUrl;
    }
  }

  // 5. Insert compliance_reports row
  const { data: reportData, error: reportError } = await supabase.rpc(
    "insert_compliance_report",
    {
      p_tenant_id: auth.tenantId,
      p_report_type: "compliance_program",
      p_data: program,
      p_contact_id: null,
      p_file_url: fileUrl,
    },
  );

  if (reportError) {
    console.error("insert_compliance_report error:", reportError.message);
  }

  const reportId =
    reportData && reportData.length > 0 ? reportData[0].id : null;

  // 6. Audit log
  await insertAuditLog({
    tenantId: auth.tenantId,
    action: "proof_generated",
    entityType: "compliance_report",
    entityId: reportId ?? auth.tenantId,
    details: {
      report_type: "compliance_program",
      compliance_score: program.compliance_score,
      sections_count: program.sections.length,
      file_url: fileUrl,
    },
    apiKeyId: auth.apiKeyId,
    ipAddress: ipAddress,
  });

  // 7. Return JSON program + metadata
  return jsonResponse({
    program,
    report_id: reportId,
    pdf_url: fileUrl,
  });
}

// ---- Main Handler ----

Deno.serve(async (request) => {
  if (request.method === "OPTIONS") {
    return new Response(null, { status: 204, headers: corsHeaders });
  }

  try {
    // Auth
    const auth = await requireAuth(request);
    if (auth instanceof Response) return addHeaders(auth, apiVersionHeaders());

    // Rate limiting
    const rlResult = await checkRateLimit(auth.apiKeyId, auth.tenantId);
    if (rlResult && !rlResult.allowed) {
      return rateLimitExceededResponse(rlResult, corsHeaders);
    }

    const extraHeaders: Record<string, string> = {
      ...apiVersionHeaders(),
      ...(rlResult ? rateLimitHeaders(rlResult) : {}),
    };

    if (request.method === "GET") {
      return addHeaders(await handleGetProgram(request, auth), extraHeaders);
    }

    return addHeaders(
      errorResponse("Method not allowed", "METHOD_NOT_ALLOWED", 405),
      extraHeaders,
    );
  } catch (err) {
    const message = err instanceof Error ? err.message : "Unknown error";

    if (message.includes("P0003") || message.includes("Subscription expired")) {
      return addHeaders(
        errorResponse(
          "Subscription expired. Write operations are blocked.",
          "SUBSCRIPTION_EXPIRED",
          403,
        ),
        apiVersionHeaders(),
      );
    }

    console.error("Unhandled error in api-compliance-program:", message);

    await alertFounder(
      "api-compliance-program Unhandled Error",
      `<p>Error: ${message}</p><p>Stack: ${err instanceof Error ? err.stack : "N/A"}</p>`,
    );

    return addHeaders(
      errorResponse("Internal server error", "INTERNAL_ERROR", 500),
      apiVersionHeaders(),
    );
  }
});
