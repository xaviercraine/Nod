-- ============================================
-- STEP 4: Subscription enforcement triggers
-- BUG FIX: Expired/cancelled subscriptions did not block write API access.
-- A tenant with subscription_status = 'cancelled' and expired
-- subscription_expires_at could still record consent, import contacts,
-- run pre-send checks, etc.
-- Fix: BEFORE INSERT trigger on 6 tables that checks tenant subscription.
-- ============================================

CREATE OR REPLACE FUNCTION check_subscription_active()
RETURNS TRIGGER
LANGUAGE plpgsql
AS $$
DECLARE
  v_status subscription_status;
  v_expires_at timestamptz;
BEGIN
  SELECT subscription_status, subscription_expires_at
  INTO v_status, v_expires_at
  FROM tenants
  WHERE id = NEW.tenant_id;

  IF v_status = 'cancelled' AND v_expires_at IS NOT NULL AND v_expires_at < now() THEN
    RAISE EXCEPTION 'Subscription expired. Write operations are blocked.'
      USING ERRCODE = 'P0003';
  END IF;

  RETURN NEW;
END;
$$;

CREATE TRIGGER trg_consent_records_subscription_check
  BEFORE INSERT ON consent_records
  FOR EACH ROW
  EXECUTE FUNCTION check_subscription_active();

CREATE TRIGGER trg_contacts_subscription_check
  BEFORE INSERT OR UPDATE ON contacts
  FOR EACH ROW
  EXECUTE FUNCTION check_subscription_active();

CREATE TRIGGER trg_message_checks_subscription_check
  BEFORE INSERT ON message_checks
  FOR EACH ROW
  EXECUTE FUNCTION check_subscription_active();

CREATE TRIGGER trg_unsubscribe_requests_subscription_check
  BEFORE INSERT ON unsubscribe_requests
  FOR EACH ROW
  EXECUTE FUNCTION check_subscription_active();

CREATE TRIGGER trg_sender_profiles_subscription_check
  BEFORE INSERT OR UPDATE ON sender_profiles
  FOR EACH ROW
  EXECUTE FUNCTION check_subscription_active();

CREATE TRIGGER trg_api_keys_subscription_check
  BEFORE INSERT ON api_keys
  FOR EACH ROW
  EXECUTE FUNCTION check_subscription_active();

-- ============================================
-- STEP 5: CHECK constraint — cancelled requires expiry date
-- Prevents an impossible state where subscription_status = 'cancelled'
-- but subscription_expires_at is NULL, which would silently bypass
-- the subscription check trigger.
-- ============================================

ALTER TABLE tenants
ADD CONSTRAINT chk_cancelled_requires_expiry
CHECK (
  subscription_status != 'cancelled'
  OR subscription_expires_at IS NOT NULL
);

